# ─── ai-scraper API — environment configuration ──────────────────────────────
#
# Copy to .env and fill in values before running:
#   cp .env.example .env
#
# In Docker Compose these are set in docker-compose.yml; override here for local dev.

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Optional: set to require X-API-Key header on all non-health routes.
# Leave empty to run unauthenticated (fine for local/internal use).
API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
# When running locally:  OLLAMA_HOST=http://localhost:11434
# When running via Docker Compose: OLLAMA_HOST=http://ollama:11434
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=qwen2.5:7b

# ── Job Queue ─────────────────────────────────────────────────────────────────
# Number of concurrent scrape/crawl jobs processed in parallel.
# Keep at 1-2 to avoid hammering Ollama; increase for pure cheerio workloads.
WORKER_CONCURRENCY=2

# ── Scraper Defaults ─────────────────────────────────────────────────────────
# Default crawl / sitemap caps when callers don't send them explicitly.
DEFAULT_MAX_PAGES=20
DEFAULT_CONCURRENCY=3
DEFAULT_DELAY_MS=200
