# ─── ai-scraper API v3.1 — environment configuration ─────────────────────────
#
# Copy to .env:  cp .env.example .env

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# API authentication (leave empty to disable; generate with: openssl rand -hex 32)
API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
# Local:  http://localhost:11434
# Docker: http://ollama:11434
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=qwen2.5:7b

# ── Redis (optional — enables persistent job store) ───────────────────────────
# Leave empty for in-memory store (fine for dev)
# Docker: redis://:yourpassword@redis:6379
REDIS_URL=
REDIS_PASSWORD=

# ── SQLite (result persistence) ───────────────────────────────────────────────
DB_PATH=./output/scraper.db

# ── Job Queue ─────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2

# ── Scraper Defaults ─────────────────────────────────────────────────────────
DEFAULT_MAX_PAGES=20
DEFAULT_CONCURRENCY=3
DEFAULT_DELAY_MS=200

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins, or * for all (dev only)
CORS_ORIGINS=*
