# ─── ai-scraper API v3.2 ──────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=qwen2.5:7b

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=
DB_PATH=./output/scraper.db

# ── Queue ─────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2

# ── Scraper defaults ──────────────────────────────────────────────────────────
DEFAULT_MAX_PAGES=20
DEFAULT_CONCURRENCY=3
DEFAULT_DELAY_MS=200

# ── Tor (free rotating IPs) ───────────────────────────────────────────────────
# Set USE_TOR=true to enable. Requires Tor installed: apt-get install tor
# OR use Docker Compose which runs the tor container automatically.
USE_TOR=false
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=ai-scraper-tor
# Rotate IP every N requests (10 = new IP every 10 scrapes)
TOR_ROTATE_EVERY=10

# ── Manual proxies (optional, paid) ──────────────────────────────────────────
# Comma-separated list. Used round-robin, falls back to Tor.
# Example: http://user:pass@proxy1.com:8080,socks5://proxy2.com:1080
PROXY_LIST=

# ── Rate limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute
CORS_ORIGINS=*
