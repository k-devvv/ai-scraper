# ai-scraper — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored. NEVER commit .env to version control.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
LOG_LEVEL=info

# ─── Ollama (local LLM) ───────────────────────────────────────────────────────
# URL of your local Ollama instance
OLLAMA_URL=http://localhost:11434

# Default model for extraction. Options: qwen2.5:7b, llama3.2:3b, gemma3:4b
OLLAMA_MODEL=qwen2.5:7b

# Max time to wait for Ollama response (ms)
OLLAMA_TIMEOUT_MS=60000

# ─── Redis (BullMQ queue + rate limiting) ────────────────────────────────────
# Required for job persistence and rate limiting.
# Defaults to local Redis. Use Docker: docker run -p 6379:6379 redis:alpine
REDIS_URL=redis://localhost:6379

# ─── API Security ────────────────────────────────────────────────────────────
# Optional. If set, all HTTP API requests must include: X-API-Key: <value>
# Leave blank for open local access (dev mode).
API_KEY=

# ─── Scraper Limits ──────────────────────────────────────────────────────────
# Max parallel browser pages (keep ≤3 on 6GB VRAM)
MAX_CONCURRENCY=3

# Hard ceiling on pages per crawl (overrides --pages flag if lower)
MAX_PAGES=200

# Max crawl depth
MAX_DEPTH=5

# Playwright page load timeout (ms)
PAGE_TIMEOUT_MS=30000

# Delay between requests per domain (ms) — be a polite crawler
REQUEST_DELAY_MS=500

# ─── Output ──────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
