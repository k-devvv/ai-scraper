{
  "name": "ai-scraper",
  "version": "3.2.0",
  "description": "Production-grade scraper: TLS spoof + Tor rotation + Stealth Playwright + Ollama AI",
  "type": "commonjs",
  "scripts": {
    "scrape": "npx tsx src/cli.ts scrape",
    "crawl": "npx tsx src/cli.ts crawl",
    "sitemap": "npx tsx src/cli.ts sitemap",
    "start:api": "npx tsx api/server.ts",
    "start:api:prod": "node -r dotenv/config dist/api/server.js",
    "build": "tsc --project tsconfig.build.json",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:coverage": "npx vitest run --coverage",
    "batch": "npx tsx src/cli.ts batch"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "axios": "^1.7.2",
    "better-sqlite3": "^11.3.0",
    "bullmq": "^5.12.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "got-scraping": "^3.2.9",
    "https-proxy-agent": "^7.0.5",
    "ioredis": "^5.4.1",
    "ollama": "^0.5.9",
    "p-limit": "^4.0.0",
    "p-queue": "^7.4.1",
    "p-retry": "^5.1.2",
    "playwright": "^1.44.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "socks-proxy-agent": "^8.0.4",
    "turndown": "^7.1.2",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20.14.2",
    "@types/turndown": "^5.0.4",
    "pino-pretty": "^11.2.1",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^4.1.9"
  }
}
